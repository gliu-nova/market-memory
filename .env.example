# Etherscan API (https://etherscan.io/apidashboard)
# Create a free key and paste it below. Never commit real keys.
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Default chain (name or numeric id). Per-address override via watchlist.
# Examples: ethereum / 1, base / 8453, arbitrum / 42161
ETHERSCAN_CHAIN=ethereum
ETHERSCAN_CHAIN_ID=1
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_DB_PATH=data/etherscan.db
# Free tier: stay under ~5 calls/sec; 0.25s is a safe default
ETHERSCAN_RATE_LIMIT_DELAY=0.25
ETHERSCAN_LARGE_TRANSFER_ETH=100
# Default watchlist path (optional)
# ETHERSCAN_WATCHLIST_PATH=data/watchlist.yaml
# Whale alerts after each ingest (1/true/yes)
# ETHERSCAN_WHALE_ALERTS=1
# ETHERSCAN_WHALE_ALERTS_JSON=data/whale_alerts.json
# Optional: write raw API JSON backups (leave empty to disable)
# ETHERSCAN_JSON_BACKUP_DIR=data/etherscan_raw
